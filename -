// Keyboard paging: keep normal scrolling soft, but make Page Down/Page Up land on section starts.
(function(){
  function getSections(){
    return Array.prototype.slice.call(document.querySelectorAll('body > section'));
  }
  function getNavHeight(){
    var nav = document.querySelector('.nav');
    return nav ? nav.offsetHeight : 72;
  }
  function isTypingTarget(el){
    return !!(el && (el.isContentEditable || /^(INPUT|TEXTAREA|SELECT)$/.test(el.tagName)));
  }
  function goToSection(section){
    if(!section) return;
    window.scrollTo({
      top: Math.max(section.offsetTop - getNavHeight(), 0),
      behavior: 'smooth'
    });
  }

  document.addEventListener('keydown', function(e){
    if(window.innerWidth < 1025) return;
    if(e.defaultPrevented || e.altKey || e.ctrlKey || e.metaKey) return;
    if(e.key !== 'PageDown' && e.key !== 'PageUp') return;
    if(isTypingTarget(document.activeElement)) return;

    var sections = getSections();
    if(!sections.length) return;

    var currentTop = window.scrollY + getNavHeight() + 8;
    e.preventDefault();

    if(e.key === 'PageDown'){
      var next = sections.find(function(section){
        return section.offsetTop > currentTop;
      });
      if(next){
        goToSection(next);
      }
      return;
    }

    var previous = sections.slice().reverse().find(function(section){
      return section.offsetTop < window.scrollY - 8;
    });
    if(previous){
      goToSection(previous);
    } else {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
})();
