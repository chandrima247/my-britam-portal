    var dental = refs.dentalToggle.checked ? plan.premiums.dental * count : 0;
    var optical = refs.opticalToggle.checked ? plan.premiums.optical * count : 0;
    var lastExpense = plan.premiums.lastExpense * count;
    var subtotal = inpatient + outpatient + dental + optical + lastExpense;
    var levy = subtotal * levyRate;
    var total = subtotal + levy + stampDuty;

    return {
      plan: plan,
      count: count,
      children: clampCount(refs.childrenCount, 1),
      dependents: clampCount(refs.dependentsCount, 0),
      inpatient: inpatient,
      outpatient: outpatient,
