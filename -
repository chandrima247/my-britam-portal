
// Hero Carousel
(function(){
  var slides = Array.prototype.slice.call(document.querySelectorAll('#heroCarousel .hero-slide'));
  var dotWrap = document.getElementById('heroDots');
  var dots = dotWrap ? Array.prototype.slice.call(dotWrap.querySelectorAll('.hero-dot')) : [];
  var prev = document.getElementById('heroPrev_removed');
  var next = document.getElementById('heroNext_removed');
  var cur = 0, total = slides.length, timer;

  if(!slides.length){ return; }

  if(dotWrap && dots.length !== total){
    dotWrap.innerHTML = '';
    dots = slides.map(function(_, i){
      var dot = document.createElement('button');
      dot.className = 'hero-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', 'Slide ' + (i + 1));
      dot.type = 'button';
      dotWrap.appendChild(dot);
      return dot;
    });
  }

  function goTo(n){
    cur = (n + total) % total;
    slides.forEach(function(slide, i){ slide.classList.toggle('active', i === cur); });
    dots.forEach(function(dot, i){ dot.classList.toggle('active', i === cur); });
  }
  function autoPlay(){ clearInterval(timer); timer = setInterval(function(){ goTo(cur + 1); }, 5000); }
  function reset(){ autoPlay(); }

  dots.forEach(function(d, i){ d.addEventListener('click', function(){ goTo(i); reset(); }); });
  if(prev) prev.addEventListener('click', function(){ goTo(cur - 1); reset(); });
  if(next) next.addEventListener('click', function(){ goTo(cur + 1); reset(); });

  var el = document.getElementById('heroCarousel');
  if(el){
    el.addEventListener('mouseenter', function(){ clearInterval(timer); });
    el.addEventListener('mouseleave', autoPlay);
  }
  goTo(0);
  autoPlay();
})();

